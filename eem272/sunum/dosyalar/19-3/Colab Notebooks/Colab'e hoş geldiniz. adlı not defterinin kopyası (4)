_laplace_transform(denklem, s, t)\n","        return str(sonuc)\n","    except Exception as e:\n","        return f\"Hata oluştu: {str(e)}\"\n","\n","tools = [laplace_donustur, ters_laplace_donustur]\n","\n","# 2. AJAN KONFİGÜRASYONU VE TEST\n","config = types.GenerateContentConfig(\n","    tools=tools,\n","    temperature=0.0,\n","    system_instruction=\"Sen uzman bir Elektrik-Elektronik mühendisliği asistanısın. Laplace dönüşümlerini KESİNLİKLE kendin hesaplama, her zaman sana verilen araçları kullan.\"\n",")\n","\n","chat = client.chats.create(model=\"gemini-2.5-flash\", config=config)\n","\n","test_mesaji = \"t**2 * exp(-3*t) fonksiyonunun Laplace dönüşümünü hesaplar mısın?\"\n","print(f\"Siz: {test_mesaji}\\n\")\n","\n","response = chat.send_message(test_mesaji)\n","\n","if response.function_calls:\n","    for call in response.function_calls:\n","        print(f\"Sistem: Ajan '{call.name}' aracını seçti. Parametreler: {call.args}\\n\")\n","\n","        # Aracı arka planda çalıştırıyoruz\n","        if call.name == \"laplace_donustur\":\n","            ham_sonuc = laplace_donustur(**call.args)\n","        elif call.name == \"ters_laplace_donustur\":\n","            ham_sonuc = ters_laplace_donustur(**call.args)\n","\n","        print(f\"Araç Çıktısı (Hesaplanan): {ham_sonuc}\\n\")\n","\n","        # Sonucu ajana verip nihai cümleyi kurmasını istiyoruz\n","        nihai_yanit = chat.send_message(\n","            types.Part.from_function_response(name=call.name, response={\"result\": ham_sonuc})\n","        )\n","        print(f\"Ajan: {nihai_yanit.text}\")\n","else:\n","     print(f\"Ajan doğrudan cevap verdi: {response.text}\")"],"metadata":{"id":"xqU2UKqBOjOZ","executionInfo":{"status":"aborted","timestamp":1778325140626,"user_tz":-180,"elapsed":31032,"user":{"displayName":"","userId":""}}},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# SÜREKLİ DİNLEYEN AJAN (CHAT LOOP)\n","\n","# LaTeX ve düzenli çıktı için talimatı güncelledik\n","conf